// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
  output          = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- 1. USER & PROFILE CORE ---

enum UserRole {
  WORKER
  EMPLOYER
  ADMIN
}

enum UserStatus {
  PENDING_OTP
  ACTIVE
  SUSPENDED
}

model User {
  id        String     @id @db.Uuid
  email     String     @unique
  phone     String     @unique
  name      String
  role      UserRole   @default(WORKER)
  status    UserStatus @default(PENDING_OTP)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  profile Profile?

  // Relations
  skills      UserSkill[]
  badges      UserBadge[]
  postedGigs  Gig[]              @relation("EmployerGigs")
  assignments Assignment[]       @relation("WorkerAssignments")
  completions ModuleCompletion[]
  reports     Report[]
  notifications Notification[]

  // Self-referencing Rating relationship
  ratingsGiven Rating[]  @relation("Rater")
  ratingsRecv  Rating[]  @relation("Ratee")
  disputes     Dispute[]

  // Admin & Support relations
  supportTickets SupportTicket[]
  activities     UserActivity[]
}

model Profile {
  id                 String  @id @default(uuid())
  userId             String  @unique @db.Uuid
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                String?
  location           String?
  availabilityStatus Boolean @default(true)
  portfolio          Json? // [{ id, title, description, url, type }]
  verified           Boolean @default(false)

  // Employer-specific fields (null for workers)
  companyName        String?
  companyDescription String?
  companyLogo        String?   // URL to uploaded company logo
  industry           String?
  website            String?
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   // 'REVISION_REQUESTED', 'APPROVED', 'SUBMITTED', etc.
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// --- 2. TRUST & SKILL ECOSYSTEM ---

model Skill {
  id       String @id @default(uuid())
  name     String @unique
  category String

  users           UserSkill[]
  gigs            GigSkill[]
  trainingModules TrainingModule[]
}

model UserSkill {
  id         String    @id @default(uuid())
  userId     String    @db.Uuid
  skillId    String
  level      Int       @default(1) // 1-5 scale
  verified   Boolean   @default(false)
  verifiedAt DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
}

model Badge {
  id          String @id @default(uuid())
  name        String @unique
  description String
  criteria    String

  users UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String   @db.Uuid
  badgeId   String
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

// --- 3. GIG & EXECUTION WORKFLOW --- [cite: 332, 472]

enum GigStatus {
  OPEN
  ASSIGNED
  COMPLETED
  CLOSED
  CANCELLED
}

enum GigCategory {
  TRANSLATION
  MARKETING
  DATA_ENTRY
  BUG_HUNTING
  AI_LABELING
  RESEARCH
}

enum WorkType {
  REMOTE
  ON_SITE
  HYBRID
}

enum GigDifficulty {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

model Gig {
  id          String      @id @default(uuid())
  employerId  String      @db.Uuid
  employer    User        @relation("EmployerGigs", fields: [employerId], references: [id], onDelete: Cascade)
  title       String
  description String
  category    GigCategory
  workType    WorkType    @default(REMOTE)
  payAmount   Decimal     @db.Decimal(10, 2)
  currency    String      @default("KES")
  location    String
  difficulty  GigDifficulty @default(BEGINNER)
  status      GigStatus   @default(OPEN)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  expiresAt   DateTime?

  // Dynamic Evidence Requirement
  // Format: [{"tag": "translated_doc", "label": "Translated Document", "type": "FILE", "accept": [".pdf"], "maxSizeMB": 10, "min": 1, "required": true}]
  evidenceTemplate Json

  skills      GigSkill[]
  assignments Assignment[]
}

model GigSkill {
  id            String @id @default(uuid())
  gigId         String
  skillId       String
  requiredLevel Int    @default(1)

  gig   Gig   @relation(fields: [gigId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([gigId, skillId])
}

enum AssignmentStatus {
  OFFERED
  ACCEPTED
  SUBMITTED
  REVISION_REQUESTED
  APPROVED
  PAID
  DISPUTED
  FAILED
  CANCELLED
  REJECTED
}

model Assignment {
  id                   String           @id @default(uuid())
  gigId                String
  workerId             String           @db.Uuid
  status               AssignmentStatus @default(OFFERED)
  offeredAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  acceptedAt           DateTime?
  submittedAt          DateTime?
  approvedAt           DateTime?
  paidAt               DateTime?
  deadlineAt           DateTime?
  autoApproveAt        DateTime?
  extensionRequestedAt DateTime?
  extensionReason      String?
  isExtensionGranted   Boolean?
  completionNotes      String?
  revisionNotes        String?

  gig    Gig  @relation(fields: [gigId], references: [id], onDelete: Cascade)
  worker User @relation("WorkerAssignments", fields: [workerId], references: [id], onDelete: Cascade)

  evidence    Evidence[]
  transactions Transaction[]
  ratings     Rating[]
  dispute     Dispute?
}

model Evidence {
  id             String     @id @default(uuid())
  assignmentId   String
  assignment     Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  fileUrl        String
  evidenceType   String // VIDEO, PHOTO, LINK, FILE 
  requirementTag String // Links back to a specific item in the Gig's evidenceTemplate
  submittedAt    DateTime   @default(now())
  validated      Boolean    @default(false)
  validatorNotes String?
}

// --- 4. FINANCIALS & FEEDBACK

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  RELEASED
}

enum TransactionType {
  DEPOSIT_TO_ESCROW
  PAYOUT_TO_WORKER
  REFUND_TO_EMPLOYER
}

model Transaction {
  id                String            @id @default(uuid())
  assignmentId      String            
  assignment        Assignment        @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  amount            Int // Stored in Cents/Base unit for Daraja KES
  currency          String            @default("KES")
  type              TransactionType
  status            TransactionStatus @default(PENDING)
  mpesaRef          String?           @unique // The critical Safaricom reference 
  checkoutRequestId String?           @unique // For STK Push tracking
  merchantRequestId String? // For STK Push tracking
  receiptNumber     String?           @unique // The actual M-Pesa receipt
  metadata          Json? // Store full Safaricom callback payload
  initiatedAt       DateTime          @default(now())
  completedAt       DateTime?
  updatedAt         DateTime          @updatedAt
  retryCount        Int               @default(0)

  @@unique([assignmentId, type])
}

model Rating {
  id           String     @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  raterId      String     @db.Uuid
  rateeId      String     @db.Uuid
  score        Int // 1-5 overall
  dimensions   Json?      // { quality: 1-5, communication: 1-5, timeliness: 1-5 }
  comment      String?
  createdAt    DateTime   @default(now())

  rater User @relation("Rater", fields: [raterId], references: [id], onDelete: Cascade)
  ratee User @relation("Ratee", fields: [rateeId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, raterId])
}

model Dispute {
  id           String     @id @default(uuid())
  assignmentId String     @unique
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  raisedById   String     @db.Uuid
  raisedBy     User       @relation(fields: [raisedById], references: [id], onDelete: Cascade)
  reason       String
  status       String     @default("OPEN") // OPEN, IN_REVIEW, RESOLVED_FOR_WORKER, RESOLVED_FOR_EMPLOYER, CLOSED
  resolution   String?
  adminNotes   String?
  evidenceUrls Json?      // [{url: String, label: String, uploadedBy: String}]
  resolvedBy   String?    @db.Uuid
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  resolvedAt   DateTime?
}

// --- 5. TRAINING & REPORTING ---

model TrainingModule {
  id              String @id @default(uuid())
  title           String
  skillId         String
  videoUrl        String?
  docUrl          String?
  passScore       Int    @default(80)
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())

  skill           Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  completions     ModuleCompletion[]
  questions       Question[]
}

model Question {
  id              String @id @default(uuid())
  moduleId        String
  text            String
  
  module          TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  options         Option[]
}

model Option {
  id              String @id @default(uuid())
  questionId      String
  text            String
  isCorrect       Boolean @default(false)
  
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model ModuleCompletion {
  id          String   @id @default(uuid())
  moduleId    String
  userId      String   @db.Uuid
  score       Int
  passed      Boolean
  completedAt DateTime @default(now())

  module TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model Report {
  id          String   @id @default(uuid())
  userId      String   @db.Uuid
  reportType  String // EARNINGS, HISTORY, PERFORMANCE, SPENDING, GIG_ACTIVITY, WORKER_REVIEW, PAYMENT_LEDGER, HIRING_EFFICIENCY, PLATFORM_ACTIVITY, FINANCIAL_RECON, USER_TRUST
  params      Json? // Filters used to generate report
  generatedAt DateTime @default(now())
  fileUrl     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- 6. SUPPORT & ADMIN ---

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketCategory {
  ACCOUNT_CHANGE
  PAYMENT_ISSUE
  DISPUTE_HELP
  BUG_REPORT
  GENERAL
}

model SupportTicket {
  id          String         @id @default(uuid())
  userId      String         @db.Uuid
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    TicketCategory
  subject     String
  message     String
  status      TicketStatus   @default(OPEN)
  adminNotes  String?
  resolvedBy  String?        @db.Uuid
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  resolvedAt  DateTime?
}

model UserActivity {
  id        String   @id @default(uuid())
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // LOGIN, LOGOUT, GIG_CREATED, APPLICATION_SENT, DISPUTE_RAISED, etc.
  metadata  Json?    // Flexible context data for the action
  ipAddress String?
  createdAt DateTime @default(now())
}
